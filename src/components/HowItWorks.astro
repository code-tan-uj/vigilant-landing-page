<section id="how">
  <div class="section-eyebrow reveal">Architecture</div>
  <h2 class="section-title reveal reveal-delay-1">Zero Disruption.<br /><em>Total Intelligence.</em></h2>
  <div class="steps">
    <div class="step reveal">
      <div class="step-num">01</div>
      <div class="step-title">Existing CCTV</div>
      <p class="step-desc">Any IP or RTSP camera, NVR or DVR. No replacement, no upgrade, no capex.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step reveal reveal-delay-1">
      <div class="step-num">02</div>
      <div class="step-title">Edge Gateway</div>
      <p class="step-desc">A small device installed on your LAN. No inbound firewall ports. secure tunnel encrypted tunnel only.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step reveal reveal-delay-2">
      <div class="step-num">03</div>
      <div class="step-title">AI Cloud Engine</div>
      <p class="step-desc">Deep learning models trained for your environment. Real-time inference.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step reveal reveal-delay-3">
      <div class="step-num">04</div>
      <div class="step-title">Instant Alerts</div>
      <p class="step-desc">WhatsApp, SMS and dashboard — with snapshot, zone, timestamp and violation type.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step reveal reveal-delay-4">
      <div class="step-num">05</div>
      <div class="step-title">Reports & Audit</div>
      <p class="step-desc">Shift PDFs, compliance scores, clip evidence. FSSAI, ISO 22000, HACCP ready.</p>
    </div>
  </div>
</section>

