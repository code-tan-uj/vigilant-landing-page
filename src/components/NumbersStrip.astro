---
---

<div id="numbers">
  <div class="numbers-grid">
    <div class="num-item reveal">
      <div class="num-val"><span class="counter" data-target="40">0</span><span class="num-suffix">s</span></div>
      <div class="num-label">Max alert response</div>
    </div>
    <div class="num-item reveal reveal-delay-1">
      <div class="num-val"><span class="counter" data-target="98">0</span><span class="num-suffix">.5%</span></div>
      <div class="num-label">Detection accuracy</div>
    </div>
    <div class="num-item reveal reveal-delay-2">
      <div class="num-val"><span class="counter" data-target="10">0</span><span class="num-suffix"> days</span></div>
      <div class="num-label">To go live</div>
    </div>
    <div class="num-item reveal reveal-delay-3">
      <div class="num-val"><span class="counter" data-target="0">0</span><span class="num-suffix"> new cams</span></div>
      <div class="num-label">Zero hardware required</div>
    </div>
  </div>
</div>

<style is:global>
  /* Numbers strip is styled in global.css */
</style>
