<section id="deployment">
  <div class="section-eyebrow reveal">Deployment</div>
  <h2 class="section-title reveal reveal-delay-1">Two Paths.<br /><em>One Platform.</em></h2>
  <div class="deploy-grid">
    <div class="deploy-card reveal">
      <div class="deploy-title">Cloud Direct</div>
      <p class="deploy-sub">Quick setup for POCs and smaller deployments. RTSP stream connected directly to cloud.</p>
      <div class="deploy-specs">
        <div class="deploy-spec"><span class="deploy-spec-label">Inbound Ports</span><span class="deploy-spec-val">Port 554 (RTSP)</span></div>
        <div class="deploy-spec"><span class="deploy-spec-label">Hardware</span><span class="deploy-spec-val">None required</span></div>
        <div class="deploy-spec"><span class="deploy-spec-label">Best For</span><span class="deploy-spec-val">POC / small sites</span></div>
        <div class="deploy-spec"><span class="deploy-spec-label">Setup Time</span><span class="deploy-spec-val">Same day</span></div>
      </div>
    </div>
    <div class="deploy-card featured reveal reveal-delay-1">
      <div class="deploy-badge">Recommended</div>
      <div class="deploy-title">On-Premise Gateway</div>
      <p class="deploy-sub">Enterprise-grade. AI Edge processing device on your LAN — encrypted outbound tunnel only. Zero inbound ports.</p>
      <div class="deploy-specs">
        <div class="deploy-spec"><span class="deploy-spec-label">Inbound Ports</span><span class="deploy-spec-val">None — outbound only</span></div>
        <div class="deploy-spec"><span class="deploy-spec-label">Hardware</span><span class="deploy-spec-val">AI Edge processing device (provided by VL)</span></div>
        <div class="deploy-spec"><span class="deploy-spec-label">Best For</span><span class="deploy-spec-val">Enterprise & large events</span></div>
        <div class="deploy-spec"><span class="deploy-spec-label">Security</span><span class="deploy-spec-val">secure tunnel / TLS</span></div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Deployment section is styled in global.css */
</style>
