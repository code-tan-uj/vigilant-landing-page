---
import CapabilityCard from './CapabilityCard.astro';

const capabilities = [
  {
    number: '01',
    icon: '<path d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"></path>',
    title: 'PPE & Hygiene Compliance',
    description: 'Real-time detection of missing hard hats, masks, gloves and safety vests. Instant WhatsApp alerts with photographic evidence — shift log exported for audits.',
    delay: '',
  },
  {
    number: '02',
    icon: '<path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>',
    title: 'SOP Compliance',
    description: 'AI verifies step-by-step standard operating procedures on every production cycle. Violation clips flagged with timestamps — zero manual review required.',
    delay: 'reveal-delay-1',
  },
  {
    number: '03',
    icon: '<path d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3"></path>',
    title: 'Operator Efficiency',
    description: 'Per-workstation output vs target, idle time breakdown, cycle time analysis. Colour-coded live dashboard and shift-wise PDF reports every day.',
    delay: 'reveal-delay-2',
  },
  {
    number: '04',
    icon: '<path d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 019 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"></path><path d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"></path>',
    title: 'Fire & Smoke Detection',
    description: 'Sub-40 second detection and escalation across all zones — grinding, packaging, warehousing. Simultaneous Email, WhatsApp, SMS and dashboard notification.',
    delay: '',
  },
  {
    number: '05',
    icon: '<path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path>',
    title: 'Restricted Zone Security',
    description: 'R&D labs, ingredient stores and hazardous areas monitored 24×7. Instant alerts the moment an unauthorised person enters a defined boundary.',
    delay: 'reveal-delay-1',
  },
  {
    number: '06',
    icon: '<path d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"></path>',
    title: 'Command Dashboard',
    description: 'All camera feeds, KPIs and alerts in one screen. Accessible via web browser and iOS/Android app. No software installation. Role-based access control.',
    delay: 'reveal-delay-2',
  },
];
---

<section id="capabilities">
  <div class="section-eyebrow reveal">Platform</div>
  <h2 class="section-title reveal reveal-delay-1">What <em>CrowdSense™</em><br />Sees For You</h2>
  <div class="cap-grid">
    {capabilities.map((cap) => (
      <CapabilityCard
        number={cap.number}
        icon={cap.icon}
        title={cap.title}
        description={cap.description}
        delay={cap.delay}
      />
    ))}
  </div>
</section>

<style is:global>
  /* Capabilities grid is styled in global.css */
</style>
