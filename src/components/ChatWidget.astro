---
// Floating liquid-glass chat widget.
// Flow: branching questionnaire with predefined, context-aware answers,
// ending in a single qualification form (name/email/phone/company/message)
// so the visitor stays engaged before we ask for contact details.
//
// IMPORTANT: all widget content below is created dynamically at runtime via
// document.createElement — Astro's scoped <style> only attaches its scoping
// attribute to elements present in the static template, so it silently
// fails to style anything created in the <script>. This file's styles are
// therefore is:global and namespaced under .vlab-chat-* to avoid collisions.
---

<div id="chat-widget">
  <button id="chat-bubble" class="vlab-chat-bubble" aria-label="Open chat" aria-expanded="false">
    <svg id="chat-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <svg id="chat-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <div id="chat-window" class="vlab-chat-window" role="dialog" aria-label="Chat with Vigilant Labs">
    <div class="vlab-chat-header">
      <div>
        <h3>Vigilant Labs</h3>
        <span class="vlab-chat-status"><span class="vlab-chat-status-dot"></span>Typically replies within 2 hours</span>
      </div>
      <button id="chat-close" class="vlab-chat-close" aria-label="Close chat">×</button>
    </div>

    <div class="vlab-chat-content" id="chat-content"></div>

    <div class="vlab-chat-footer">
      <button id="chat-back" class="vlab-chat-nav-btn" style="display:none;">← Back</button>
      <div id="chat-options" class="vlab-chat-options"></div>
    </div>
  </div>
</div>

<style is:global>
  .vlab-chat-bubble {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 40%),
      rgba(14, 14, 14, 0.7);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.12);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255,255,255,0.14);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 999;
  }

  .vlab-chat-bubble:hover { transform: scale(1.08); }

  .vlab-chat-window {
    position: fixed;
    bottom: 92px;
    right: 24px;
    width: 380px;
    max-height: 640px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 40%),
      rgba(14, 14, 14, 0.82);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    box-shadow: 0 16px 56px rgba(0, 0, 0, 0.45), inset 0 1px 0 rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(16px) scale(0.97);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.2, 0.64, 1);
  }

  .vlab-chat-window.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .vlab-chat-header {
    padding: 18px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .vlab-chat-header h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 17px;
    letter-spacing: 0.03em;
    color: var(--white);
  }

  .vlab-chat-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  .vlab-chat-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6ee787;
    box-shadow: 0 0 6px #6ee787;
  }

  .vlab-chat-close {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
  }

  .vlab-chat-close:hover { color: var(--white); }

  .vlab-chat-content {
    flex: 1;
    overflow-y: auto;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scrollbar-width: thin;
  }

  .vlab-chat-content::-webkit-scrollbar { width: 4px; }
  .vlab-chat-content::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }

  .vlab-chat-message {
    padding: 12px 14px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.55;
    animation: vlabMsgIn 0.25s ease-out;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.88);
    align-self: flex-start;
    max-width: 92%;
  }

  @keyframes vlabMsgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .vlab-chat-message p { margin: 0; }
  .vlab-chat-message p + p { margin-top: 8px; }

  .vlab-chat-footer {
    padding: 14px 20px 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .vlab-chat-nav-btn {
    align-self: flex-start;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.03em;
    cursor: pointer;
    padding: 4px 0;
    transition: color 0.2s;
  }

  .vlab-chat-nav-btn:hover { color: var(--white); }

  .vlab-chat-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .vlab-chat-option {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.82);
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 12.5px;
    text-align: left;
    font-weight: 500;
    font-family: inherit;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .vlab-chat-option:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--white);
  }

  .vlab-chat-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .vlab-chat-form input,
  .vlab-chat-form textarea {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--light);
    padding: 10px 12px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 12.5px;
  }

  .vlab-chat-form input::placeholder,
  .vlab-chat-form textarea::placeholder { color: rgba(255, 255, 255, 0.35); }

  .vlab-chat-form input:focus,
  .vlab-chat-form textarea:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .vlab-chat-form-row {
    display: flex;
    gap: 8px;
  }

  .vlab-chat-form-row input { flex: 1; min-width: 0; }

  .vlab-chat-submit {
    background: var(--white);
    color: var(--black);
    border: none;
    padding: 11px 16px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    font-size: 12.5px;
    font-family: inherit;
    transition: background 0.2s, transform 0.2s;
  }

  .vlab-chat-submit:hover { background: var(--silver); transform: translateY(-1px); }
  .vlab-chat-submit:disabled { opacity: 0.5; cursor: not-allowed; }

  @media (max-width: 480px) {
    .vlab-chat-window {
      width: calc(100vw - 32px);
      right: 16px;
      max-height: 72vh;
      bottom: 84px;
    }
  }
</style>

<script>
  interface FlowStep {
    id: string;
    bot: string;
    options?: { text: string; next: string }[];
    form?: boolean;
  }

  const FLOW: FlowStep[] = [
    {
      id: "welcome",
      bot: "Hi, I'm here to help — what brings you here today?",
      options: [
        { text: "Interested in a demo", next: "usecase" },
        { text: "Have a technical question", next: "question-type" },
        { text: "Want pricing details", next: "pricing" },
        { text: "Report an issue", next: "issue" }
      ]
    },
    {
      id: "usecase",
      bot: "Great — what's your primary industry or use case?",
      options: [
        { text: "Manufacturing & Safety (PPE, SOP)", next: "manufacturing-detail" },
        { text: "Food & Spice Manufacturing (FSSAI)", next: "food-detail" },
        { text: "Smart City / Public Safety", next: "smartcity-detail" },
        { text: "Logistics & Warehousing", next: "logistics-detail" },
        { text: "Something else", next: "contact-info" }
      ]
    },
    {
      id: "manufacturing-detail",
      bot: "Manufacturing is our core focus. CrowdSense™ detects PPE violations in real time and tracks SOP compliance across shifts — customers typically see a 30–87% drop in safety incidents, automated audit-ready reports for Factories Act compliance, and under-40-second alert latency.",
      options: [
        { text: "Yes, schedule a demo", next: "contact-info" },
        { text: "What does it cost?", next: "pricing" },
        { text: "← Back", next: "usecase" }
      ]
    },
    {
      id: "food-detail",
      bot: "For food & spice manufacturing, CrowdSense™ helps you meet FSSAI, ISO 22000, and HACCP requirements by monitoring PPE compliance, line hygiene adherence, and hazardous-area access — with automated compliance reporting. Typical deployment: 10 days, zero new hardware.",
      options: [
        { text: "Schedule a demo", next: "contact-info" },
        { text: "What does it cost?", next: "pricing" },
        { text: "← Back", next: "usecase" }
      ]
    },
    {
      id: "smartcity-detail",
      bot: "For smart cities, we handle crowd safety, perimeter security, and incident detection across 500+ camera feeds simultaneously, with sub-40-second alert latency. Edge processing keeps footage on-premise — ideal for command centres, mass gatherings, and transit hubs.",
      options: [
        { text: "Request a pilot", next: "contact-info" },
        { text: "Tell me about security", next: "security" },
        { text: "← Back", next: "usecase" }
      ]
    },
    {
      id: "logistics-detail",
      bot: "For logistics & warehousing: restricted-zone monitoring, vehicle/forklift proximity alerts, worker safety tracking, and shift efficiency metrics — customers see 40–60% fewer incidents, on top of your existing CCTV with zero capex.",
      options: [
        { text: "Schedule a demo", next: "contact-info" },
        { text: "← Back", next: "usecase" }
      ]
    },
    {
      id: "question-type",
      bot: "Sure — what would you like to know more about?",
      options: [
        { text: "How does it work technically?", next: "tech-answer" },
        { text: "Data privacy & compliance", next: "privacy-answer" },
        { text: "Deployment & integration", next: "deployment-answer" },
        { text: "← Back", next: "welcome" }
      ]
    },
    {
      id: "tech-answer",
      bot: "CrowdSense™ is edge-first: your existing CCTV feeds connect over an outbound-only encrypted tunnel — no inbound firewall ports needed. AI models run locally for instant detection, with encrypted backup to the cloud if you want it.",
      options: [
        { text: "Tell me about security", next: "security" },
        { text: "Ready to see a demo", next: "contact-info" },
        { text: "← Back", next: "question-type" }
      ]
    },
    {
      id: "privacy-answer",
      bot: "We're built around India's DPDP Act 2023, the Factories Act 1948, FSSAI, ISO 22000, and (where relevant) GDPR/CCPA. Video is processed on-premise — we extract only metadata (detections, timestamps, bounding boxes), never raw footage. You own all footage; retention is 7–30 days by default, and facial recognition is off unless you explicitly enable it.",
      options: [
        { text: "Read the full privacy policy", next: "policy-link" },
        { text: "Request a demo", next: "contact-info" },
        { text: "← Back", next: "question-type" }
      ]
    },
    {
      id: "deployment-answer",
      bot: "Edge Gateway (recommended) installs on your LAN in 2–3 hours, no code required. Or Cloud Direct connects your RTSP stream directly for quick POCs. Either way: live alerts within 10 days, automated reports, and WhatsApp/SMS/email notifications.",
      options: [
        { text: "Schedule a deployment call", next: "contact-info" },
        { text: "← Back", next: "question-type" }
      ]
    },
    {
      id: "pricing",
      bot: "Pricing scales with camera count:\n• Starter — ₹4,999/camera/month (1–10 cameras)\n• Growth — ₹3,999/camera/month (11–50 cameras)\n• Enterprise — custom (50+ cameras)\n\nPlus a one-time Edge Gateway setup fee of ₹49,990. No new cameras needed — we work with what you already have.",
      options: [
        { text: "Get a custom quote", next: "contact-info" },
        { text: "← Back", next: "welcome" }
      ]
    },
    {
      id: "security",
      bot: "Security highlights:\n• TLS 1.3 in transit, AES-256 at rest\n• Edge processing — video never leaves your facility by default\n• Outbound-only secure tunnel, no open inbound ports\n• SOC 2 Type II certified hosting\n• ₹2 crore cyber liability cover\n\nAll data stays yours — auditable, exportable, deletable on request.",
      options: [
        { text: "Read the full policy", next: "policy-link" },
        { text: "Request a demo", next: "contact-info" },
        { text: "← Back", next: "question-type" }
      ]
    },
    {
      id: "issue",
      bot: "Sorry to hear that. Give us a few details below and we'll escalate to our support team right away.",
      options: [
        { text: "Submit details", next: "contact-info" },
        { text: "← Back", next: "welcome" }
      ]
    },
    {
      id: "policy-link",
      bot: "Full documents are here:\n• Privacy Policy — vigilantlabs.in/privacy\n• Terms of Service — vigilantlabs.in/terms\n\nBoth are compliant with India's DPDP Act 2023 and international standards.",
      options: [
        { text: "Ready for a demo", next: "contact-info" },
        { text: "← Back", next: "welcome" }
      ]
    },
    {
      id: "contact-info",
      bot: "Great — just need a few details and our team will reach out.",
      form: true
    },
    {
      id: "success",
      bot: "You're all set. Our team will reach out within 2 hours at the email you provided.",
      options: [{ text: "Start a new conversation", next: "welcome" }]
    }
  ];

  const FORMSPREE_ENDPOINT = "https://formspree.io/f/meokedrq";

  const chatBubble = document.getElementById("chat-bubble")!;
  const chatWindow = document.getElementById("chat-window")!;
  const chatClose = document.getElementById("chat-close")!;
  const chatContent = document.getElementById("chat-content")!;
  const chatOptions = document.getElementById("chat-options")!;
  const chatBack = document.getElementById("chat-back")!;
  const iconOpen = document.getElementById("chat-icon-open")!;
  const iconClose = document.getElementById("chat-icon-close")!;

  let history: string[] = ["welcome"];
  let hasOpened = false;

  function setOpen(open: boolean) {
    chatWindow.classList.toggle("open", open);
    chatBubble.setAttribute("aria-expanded", String(open));
    iconOpen.style.display = open ? "none" : "block";
    iconClose.style.display = open ? "block" : "none";
  }

  function scrollToBottom() {
    setTimeout(() => { chatContent.scrollTop = chatContent.scrollHeight; }, 50);
  }

  async function submitLead(payload: Record<string, string>) {
    try {
      await fetch(FORMSPREE_ENDPOINT, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ ...payload, timestamp: new Date().toISOString(), _subject: `CrowdSense™ chat lead — ${payload.email || "unknown"}` })
      });
      return true;
    } catch {
      return false;
    }
  }

  function renderStep(stepId: string) {
    const step = FLOW.find(s => s.id === stepId);
    if (!step) return;

    chatContent.innerHTML = "";
    chatOptions.innerHTML = "";

    const msg = document.createElement("div");
    msg.className = "vlab-chat-message";
    msg.innerHTML = `<p>${step.bot.split("\n").join("</p><p>")}</p>`;
    chatContent.appendChild(msg);

    if (step.form) {
      const form = document.createElement("form");
      form.className = "vlab-chat-form";
      form.innerHTML = `
        <div class="vlab-chat-form-row">
          <input type="text" name="name" placeholder="Name" required />
          <input type="email" name="email" placeholder="Email" required />
        </div>
        <div class="vlab-chat-form-row">
          <input type="text" name="phone" placeholder="Phone (+91...)" required />
          <input type="text" name="company" placeholder="Company" required />
        </div>
        <textarea name="message" placeholder="Anything else we should know?" rows="2"></textarea>
        <button type="submit" class="vlab-chat-submit">Send details</button>
      `;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const name = (form.querySelector('[name="name"]') as HTMLInputElement).value;
        const email = (form.querySelector('[name="email"]') as HTMLInputElement).value;
        const phone = (form.querySelector('[name="phone"]') as HTMLInputElement).value;
        const company = (form.querySelector('[name="company"]') as HTMLInputElement).value;
        const message = (form.querySelector('[name="message"]') as HTMLTextAreaElement).value;
        const submitBtn = form.querySelector(".vlab-chat-submit") as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";

        const ok = await submitLead({ name, email, phone, company, message });

        if (ok) {
          history.push("success");
          renderStep("success");
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = "Send details";
          alert("Couldn't send — please email info@vigilantlabs.in directly.");
        }
      });
      chatOptions.appendChild(form);
    } else if (step.options) {
      step.options.forEach(opt => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "vlab-chat-option";
        btn.textContent = opt.text;
        btn.addEventListener("click", () => {
          history.push(opt.next);
          renderStep(opt.next);
        });
        chatOptions.appendChild(btn);
      });
    }

    chatBack.style.display = history.length > 1 ? "block" : "none";
    scrollToBottom();
  }

  chatBubble.addEventListener("click", () => {
    const willOpen = !chatWindow.classList.contains("open");
    setOpen(willOpen);
    if (willOpen && !hasOpened) {
      hasOpened = true;
      renderStep("welcome");
    }
  });

  chatClose.addEventListener("click", () => setOpen(false));

  chatBack.addEventListener("click", () => {
    if (history.length > 1) {
      history.pop();
      renderStep(history[history.length - 1]);
    }
  });

  // Use composedPath() rather than .contains(target): by the time this
  // document-level listener runs, the button that was clicked inside the
  // chat may already have been removed from the DOM (renderStep() clears
  // and rebuilds chatOptions synchronously), which makes .contains() return
  // false for an element that WAS inside the widget when clicked — closing
  // the widget on every single interaction. composedPath() reflects the DOM
  // as it was at dispatch time, so it isn't fooled by that mutation.
  document.addEventListener("click", (e) => {
    const path = e.composedPath();
    if (!path.includes(chatWindow) && !path.includes(chatBubble)) {
      setOpen(false);
    }
  });
</script>
