---
import { Image } from 'astro:assets';
import logo from '../assets/vigilantlabslogo.png';
---

<nav id="nav" class="nav-glass">
  <a href="/" class="nav-logo">
    <div class="nav-logo-mark">
      <Image src={logo} alt="Vigilant Labs" width={28} height={28} />
      <div class="logo-scan"></div>
    </div>
    <span class="nav-logo-text">VIGILANT LABS</span>
  </a>
  <ul class="nav-links">
    <li><a href="/#capabilities">Platform</a></li>
    <li><a href="/#usecases">Use Cases</a></li>
    <li><a href="/#how">How It Works</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact</a></li>
  </ul>
  <a href="/#cta" class="nav-cta">Request Demo →</a>
</nav>

<style>
  /* Liquid glass floating pill — same 3-child flex layout as base nav in
     global.css (logo / links / cta), just restyled as an inset, rounded,
     frosted-glass bar instead of an edge-to-edge opaque one. */
  .nav-glass {
    top: 16px;
    left: 16px;
    right: 16px;
    height: 64px;
    border-radius: 999px;
    padding: 0 12px 0 28px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 40%),
      rgba(18, 18, 18, 0.55);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      inset 0 -1px 0 rgba(0, 0, 0, 0.25);
    transition: background 0.4s, border-color 0.4s, box-shadow 0.4s;
  }

  .nav-glass.scrolled {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 40%),
      rgba(12, 12, 12, 0.75);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .nav-glass .nav-cta {
    margin-left: 4px;
    border-radius: 999px;
    padding: 10px 22px;
  }

  @media (max-width: 900px) {
    .nav-glass {
      left: 12px;
      right: 12px;
      padding: 0 10px 0 20px;
    }
  }
</style>
