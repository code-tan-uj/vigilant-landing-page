---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { markdownToHtml } from '../utils/markdown';
import fs from 'fs';
import path from 'path';

const title = 'Privacy Policy — Vigilant Labs | Data Protection & DPDP Compliance';
const description = 'Comprehensive Privacy Policy for CrowdSense™ platform. Compliant with India DPDP Act 2023, Factories Act 1948, and FSSAI regulations.';

// Read the privacy policy markdown file
const privacyPath = path.join(process.cwd(), 'src/content/privacy-policy.md');
let privacyContent = '';
try {
  const rawContent = fs.readFileSync(privacyPath, 'utf-8');
  privacyContent = markdownToHtml(rawContent);
} catch (error) {
  privacyContent = '<h2>Privacy Policy</h2><p>The full privacy policy content is being loaded...</p>';
}
---

<BaseLayout title={title} description={description}>
  <Nav />

  <section class="legal-section">
    <div class="legal-container">
      <div class="legal-header">
        <h1 class="section-title reveal">Privacy <em>Policy</em></h1>
        <p class="legal-updated reveal reveal-delay-1">Last updated: July 2026 | Compliant with India DPDP Act 2023</p>
      </div>

      <div class="legal-content" set:html={privacyContent} />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  .legal-section {
    background: var(--dark);
    padding: 120px 48px;
    min-height: 100vh;
    margin-top: 64px;
  }

  .legal-container {
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
  }

  .legal-header {
    margin-bottom: 80px;
  }

  .legal-updated {
    font-size: 14px;
    color: var(--muted);
    margin-top: 16px;
  }

  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .legal-content h1 {
    display: none;
  }

  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--white);
    margin-top: 48px;
    margin-bottom: 24px;
    letter-spacing: 0.04em;
  }

  .legal-content h2:first-child {
    margin-top: 0;
  }

  .legal-content h3 {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--light);
    margin-top: 32px;
    margin-bottom: 16px;
    letter-spacing: 0.02em;
  }

  .legal-content p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
  }

  .legal-content li {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
    margin-left: 20px;
  }

  .legal-content ul {
    margin: 16px 0;
  }

  .legal-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    border: 1px solid var(--border);
    overflow-x: auto;
  }

  .legal-content table td {
    padding: 14px;
    border: 1px solid var(--border);
    font-size: 13px;
    color: var(--muted);
  }

  .legal-content table tr:first-child td {
    background: var(--panel);
    color: var(--white);
    font-weight: 600;
  }

  .legal-content a {
    color: var(--silver);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .legal-content a:hover {
    color: var(--white);
  }

  .legal-content strong {
    color: var(--white);
    font-weight: 600;
  }

  .legal-content code {
    background: var(--panel);
    color: var(--silver);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-family: var(--font-mono);
  }

  .legal-content pre {
    background: var(--panel);
    color: var(--silver);
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 16px 0;
  }

  .legal-content pre code {
    background: none;
    padding: 0;
  }

  @media(max-width:900px){
    .legal-section{
      padding: 80px 24px;
      margin-top: 64px;
    }

    .legal-content h2 {
      font-size: 22px;
    }

    .legal-content h3 {
      font-size: 16px;
    }

    .legal-content table {
      font-size: 12px;
    }

    .legal-content table td {
      padding: 10px;
    }
  }
</style>
