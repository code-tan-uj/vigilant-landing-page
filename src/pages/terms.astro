---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import fs from 'fs';
import path from 'path';

const title = 'Terms of Service — Vigilant Labs | Legal Agreement & Service Terms';
const description = 'Complete Terms of Service for CrowdSense™ platform. Covers service description, liability, data responsibility, and India-specific legal compliance.';

// Read the terms of service markdown file
const termsPath = path.join(process.cwd(), 'src/content/terms-of-service.md');
let termsContent = '';
try {
  termsContent = fs.readFileSync(termsPath, 'utf-8');
} catch (error) {
  termsContent = '## Terms of Service\n\nThe full terms of service content is being loaded...';
}
---

<BaseLayout title={title} description={description}>
  <Nav />

  <section class="legal-section">
    <div class="legal-container">
      <div class="legal-header">
        <h1 class="section-title reveal">Terms of <em>Service</em></h1>
        <p class="legal-updated reveal reveal-delay-1">Last updated: July 2026 | Governing Law: India (Maharashtra)</p>
      </div>

      <div class="legal-content markdown">
        <div set:html={termsContent.split('\n').map((line, i) => {
          if (line.startsWith('# ')) return `<h1>${line.substring(2)}</h1>`;
          if (line.startsWith('## ')) return `<h2>${line.substring(3)}</h2>`;
          if (line.startsWith('### ')) return `<h3>${line.substring(4)}</h3>`;
          if (line.startsWith('| ')) return `<table><tr>${line.split('|').slice(1, -1).map(cell => `<td>${cell.trim()}</td>`).join('')}</tr></table>`;
          if (line.startsWith('- ')) return `<li>${line.substring(2)}</li>`;
          if (line.trim() === '') return '<br/>';
          return `<p>${line}</p>`;
        }).join('')} />
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  .legal-section {
    background: var(--dark);
    padding: 120px 48px;
    min-height: 100vh;
    margin-top: 64px;
  }

  .legal-container {
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
  }

  .legal-header {
    margin-bottom: 80px;
  }

  .legal-updated {
    font-size: 14px;
    color: var(--muted);
    margin-top: 16px;
  }

  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--white);
    margin-top: 40px;
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }

  .legal-content h3 {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--light);
    margin-top: 24px;
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }

  .legal-content p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .legal-content li {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
    margin-left: 20px;
    margin-bottom: 8px;
  }

  .legal-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    border: 1px solid var(--border);
  }

  .legal-content table td {
    padding: 12px;
    border: 1px solid var(--border);
    font-size: 13px;
    color: var(--muted);
  }

  .legal-content table tr:first-child td {
    background: var(--panel);
    color: var(--white);
    font-weight: 500;
  }

  .legal-content a {
    color: var(--silver);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .legal-content a:hover {
    color: var(--white);
  }

  .legal-content strong {
    color: var(--white);
    font-weight: 600;
  }

  .legal-content code {
    background: var(--panel);
    color: var(--silver);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
  }

  @media(max-width:900px){
    .legal-section{
      padding:80px 24px;
      margin-top:64px;
    }

    .legal-content h2 {
      font-size: 22px;
    }
  }
</style>
