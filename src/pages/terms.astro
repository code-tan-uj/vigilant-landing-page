---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { markdownToHtml } from '../utils/markdown';
import fs from 'fs';
import path from 'path';

const title = 'Terms of Service — Vigilant Labs | CrowdSense™ Legal Agreement';
const description = 'Terms governing use of the CrowdSense™ platform: service description, liability, data ownership, and dispute resolution under Indian law.';

const termsPath = path.join(process.cwd(), 'src/content/terms-of-service.md');
const rawContent = fs.readFileSync(termsPath, 'utf-8');
const { html: termsContent, toc } = markdownToHtml(rawContent);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vigilantlabs.in/" },
    { "@type": "ListItem", "position": 2, "name": "Terms of Service", "item": "https://vigilantlabs.in/terms" }
  ]
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Nav />

  <section class="legal-section">
    <div class="legal-container">
      <div class="legal-header">
        <p class="legal-eyebrow reveal">Legal &amp; Compliance</p>
        <h1 class="section-title reveal">Terms of <em>Service</em></h1>
        <p class="legal-updated reveal reveal-delay-1">Last updated: July 2026 · Governing law: India (Maharashtra)</p>
      </div>

      <div class="legal-index reveal reveal-delay-2">
        <span class="legal-index-label">Jump to a section</span>
        <div class="legal-index-links">
          {toc.filter(h => h.level === 2).map(h => (
            <a href={`#${h.id}`} title={h.text}>{h.text}</a>
          ))}
        </div>
      </div>

      <div class="legal-content" set:html={termsContent} />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  .legal-section {
    background: var(--dark);
    padding: 136px 48px 160px;
    min-height: 100vh;
  }

  .legal-container {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
  }

  .legal-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .legal-header {
    margin-bottom: 40px;
  }

  .legal-updated {
    font-size: 14px;
    color: var(--muted);
    margin-top: 16px;
  }

  .legal-index {
    border: 1px solid var(--border);
    background: var(--panel);
    padding: 24px;
    margin-bottom: 56px;
  }

  .legal-index-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 16px;
  }

  .legal-index-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px 28px;
  }

  .legal-index-links a {
    font-size: 12.5px;
    color: var(--muted);
    text-decoration: none;
    line-height: 1.6;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .legal-index-links a:hover {
    color: var(--white);
    border-color: var(--border);
  }

  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .legal-content h1 { display: none; }

  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--white);
    margin-top: 44px;
    margin-bottom: 8px;
    letter-spacing: 0.03em;
    scroll-margin-top: 112px;
  }

  .legal-content h2:first-of-type { margin-top: 0; }

  .legal-content h3 {
    font-family: var(--font-display);
    font-size: 19px;
    color: var(--light);
    margin-top: 28px;
    margin-bottom: 4px;
    letter-spacing: 0.02em;
    scroll-margin-top: 112px;
  }

  .legal-content p {
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.8;
  }

  .legal-content ul,
  .legal-content ol {
    margin: 4px 0 4px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .legal-content li {
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.75;
  }

  .legal-content ol { list-style: decimal; }
  .legal-content ul { list-style: disc; }

  .legal-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }

  .legal-content .table-wrap {
    overflow-x: auto;
    margin: 12px 0;
    border: 1px solid var(--border);
  }

  .legal-content table {
    width: 100%;
    border-collapse: collapse;
    min-width: 480px;
  }

  .legal-content table td,
  .legal-content table th {
    padding: 12px 14px;
    border: 1px solid var(--border);
    font-size: 13px;
    color: var(--muted);
    text-align: left;
  }

  .legal-content table th {
    background: var(--panel);
    color: var(--white);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.02em;
  }

  .legal-content a {
    color: var(--silver);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .legal-content a:hover { color: var(--white); }

  .legal-content strong { color: var(--white); font-weight: 600; }

  .legal-content code {
    background: var(--panel);
    color: var(--silver);
    padding: 3px 7px;
    border-radius: 4px;
    font-size: 12.5px;
    font-family: var(--font-mono);
  }

  @media (max-width: 900px) {
    .legal-section {
      padding: 96px 24px 100px;
    }

    .legal-content h2 { font-size: 22px; }
    .legal-content h3 { font-size: 16px; }
  }
</style>
