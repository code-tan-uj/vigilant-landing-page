---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact — Vigilant Labs | Request a Demo';
const description = 'Get in touch with Vigilant Labs. Request a demo, ask questions, or learn how CrowdSense™ can transform your operations. Call +91 95743 32221 or email info@vigilantlabs.in.';
---

<BaseLayout title={title} description={description}>
  <Nav />

  <main>
  <section class="contact-section">
    <div class="contact-container">
      <div class="contact-header">
        <div class="section-eyebrow reveal">Contact</div>
        <h1 class="section-title reveal reveal-delay-1">Get In <em>Touch</em></h1>
        <p class="contact-intro reveal reveal-delay-2">
          Ready to see CrowdSense™ in action? Reach out to our team. We'll schedule a live demo on your cameras within 48 hours.
        </p>
      </div>

      <div class="contact-grid reveal reveal-delay-3">
        <div class="contact-card">
          <h2 class="contact-label">Email</h2>
          <a href="mailto:info@vigilantlabs.in" class="contact-link">info@vigilantlabs.in</a>
          <p class="contact-note">Fastest response. PoC setup, licensing, technical questions.</p>
        </div>

        <div class="contact-card">
          <h2 class="contact-label">Phone</h2>
          <a href="tel:+919574332221" class="contact-link">+91 95743 32221</a>
          <p class="contact-note">Call for urgent PoCs or multi-site deployments.</p>
        </div>

        <div class="contact-card">
          <h2 class="contact-label">Location</h2>
          <p class="contact-link">Pune, Maharashtra</p>
          <p class="contact-note">India</p>
        </div>
      </div>

      <div class="contact-process">
        <h2 class="contact-process-title">What Happens Next</h2>
        <div class="contact-process-grid">
          <div class="process-step">
            <div class="process-num">01. Initial Call</div>
            <p>20-min discovery. Your camera setup, compliance requirements, key use cases. No pressure.</p>
          </div>
          <div class="process-step">
            <div class="process-num">02. Live Demo</div>
            <p>Our team connects to your CCTV, trains the AI model, shows real-time detections within 48 hours.</p>
          </div>
          <div class="process-step">
            <div class="process-num">03. Custom Proposal</div>
            <p>Deployment plan, pricing, onboarding timeline tailored to your site.</p>
          </div>
          <div class="process-step">
            <div class="process-num">04. Go Live</div>
            <p>Full setup, staff training, 24/7 support. Compliance dashboard live on day 1.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  .contact-section {
    background: var(--dark);
    padding: 136px 48px 120px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .contact-container {
    max-width: 1000px;
    width: 100%;
  }

  .contact-header {
    margin-bottom: 80px;
  }

  .contact-intro {
    font-size: 18px;
    color: var(--silver);
    max-width: 600px;
    line-height: 1.7;
    margin-top: 20px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
    margin-bottom: 80px;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .contact-link {
    font-size: 18px;
    font-weight: 400;
    color: var(--silver);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-block;
  }

  .contact-link:hover {
    color: var(--white);
  }

  .contact-note {
    font-size: 13px;
    color: var(--muted);
    margin-top: 8px;
    line-height: 1.6;
  }

  .contact-process {
    border-top: 1px solid var(--border);
    padding-top: 60px;
  }

  .contact-process-title {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--white);
    margin-bottom: 40px;
    letter-spacing: 0.04em;
  }

  .contact-process-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .process-step {
    display: flex;
    flex-direction: column;
  }

  .process-num {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--white);
    margin-bottom: 8px;
  }

  .process-step p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }

  @media(max-width:900px){
    .contact-section{
      padding:96px 24px 80px;
    }
    .contact-grid{
      grid-template-columns:1fr;
      gap:40px;
    }
    .contact-process-grid{
      grid-template-columns:1fr;
    }
  }
</style>
