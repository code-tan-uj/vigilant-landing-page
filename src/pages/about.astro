---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'About — Vigilant Labs | AI CCTV Analytics India';
const description = 'Learn how Vigilant Labs transforms existing CCTV infrastructure into AI-powered operational intelligence. Founded by computer vision engineers. Compliant with India\'s Factories Act & FSSAI.';
---

<BaseLayout title={title} description={description}>
  <Nav />

  <section class="about-hero">
    <div class="about-header">
      <div class="section-eyebrow reveal">About Us</div>
      <h1 class="section-title reveal reveal-delay-1">Turning CCTV <br /> Into <em>Intelligence</em></h1>
    </div>

    <div class="about-content">
      <p class="about-intro reveal reveal-delay-2">
        Vigilant Labs reimagines CCTV infrastructure as a proactive intelligence layer. Every organization invests in surveillance — cameras are already everywhere. We unlock that existing capital by layering real-time AI analysis on top, turning passive recording into actionable operational intelligence.
      </p>

      <div class="about-section reveal reveal-delay-3">
        <h2 class="about-subtitle">Why India. Why Now.</h2>
        <p>
          India's manufacturing belt is compliance-heavy. The Factories Act 1948, OSHWC Code 2020, ISO 22000, and FSSAI regulations demand evidence-based audits. Traditional manual monitoring doesn't scale across multi-site operations. CCTV adoption is near-universal in food manufacturing, pharma, and logistics — yet most footage goes unwatched. We bridge this gap with edge-first, privacy-first AI that works with existing infrastructure.
        </p>
      </div>

      <div class="about-section reveal reveal-delay-4">
        <h2 class="about-subtitle">Founded by Engineers Who Know</h2>
        <p>
          Our team comes from leading computer vision companies. We've shipped video analysis systems at scale. We understand the gap between research and production — between promising accuracy in a lab and reliable performance in a factory.
        </p>
      </div>

      <div class="about-section reveal reveal-delay-4">
        <h2 class="about-subtitle">Compliance Baked In</h2>
        <p>
          Our platform is audit-ready: Factories Act 1948, OSHWC Code 2020, ISO 22000, FSSAI. Every detection generates timestamped evidence — clips, snapshots, KPIs — exportable as PDFs for regulatory review. No guesswork. No manual log entries.
        </p>
      </div>

      <div class="about-cta reveal reveal-delay-4">
        <p>Ready to see what CrowdSense™ can do for your operations?</p>
        <a href="/contact" class="btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  .about-hero {
    background: var(--dark);
    padding: 120px 48px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-top: 96px;
  }

  .about-header {
    margin-bottom: 60px;
  }

  .about-content {
    max-width: 700px;
  }

  .about-intro {
    font-size: 16px;
    color: var(--silver);
    margin-bottom: 48px;
    line-height: 1.8;
  }

  .about-section {
    margin-bottom: 40px;
  }

  .about-subtitle {
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-bottom: 16px;
  }

  .about-section p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.7;
  }

  .about-cta {
    margin-top: 60px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }

  .about-cta p {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 20px;
  }

  @media(max-width:900px){
    .about-hero{
      padding:80px 24px;
      margin-top:6px;
    }
  }
</style>
